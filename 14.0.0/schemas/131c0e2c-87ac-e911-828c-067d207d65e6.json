      "x-related-bo-name": "InstructionStatusTypeValues"
    },
    "RepaymentClearingSystemIdentification": {
      "type": "string",
      "description": "Repayment Clearing System Identification: A coded value or reference that uniquely identifies the clearing/settlement system through which the repayment is routed and settled.Examples\r\nIndia → \"NACH\" (auto‑debit mandates), \"NEFT\", \"RTGS\", \"UPI\".\r\nEurope → \"SEPA\" (Single Euro Payments Area).\r\nGlobal → \"SWIFT\" (cross‑border).\r\nUS → \"ACH\" (Automated Clearing House), \"Fedwire\".",
